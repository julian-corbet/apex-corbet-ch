---
import Base from '../layouts/Base.astro';
---
<Base title="09 — Breathing — corbet.ch" bodyClass="font-sans">
  <main class="min-h-screen flex flex-col">

    <header class="max-w-6xl w-full mx-auto px-6 sm:px-10 pt-10 sm:pt-14">
      <p class="font-mono text-[10px] sm:text-[11px] uppercase tracking-[0.3em] text-neutral-500">
        Julian Corbet &nbsp;/&nbsp; corbet.ch
      </p>
    </header>

    <section class="flex-1 max-w-5xl w-full mx-auto px-6 sm:px-10 flex flex-col justify-center text-center py-20">
      <h1
        class="breathe font-display font-bold leading-[0.95] tracking-[-0.022em] text-[clamp(2.5rem,9vw,7.5rem)] inline-block"
        style="color: var(--ink); transform-origin: 50% 60%;"
      >
        The world is changing.
      </h1>
      <p
        class="breathe-delay font-display italic font-medium mt-6 sm:mt-10 leading-[1.15] text-[clamp(1.4rem,4vw,2.75rem)] inline-block"
        style="color: var(--green-800); transform-origin: 50% 60%;"
      >
        Looking for a running mate?
      </p>
    </section>

    <footer class="border-t border-white/[0.06]">
      <div class="max-w-6xl mx-auto px-6 sm:px-10 py-5 sm:py-7 flex flex-wrap items-baseline gap-x-6 gap-y-2 font-mono text-[10px] sm:text-[11px] uppercase tracking-[0.3em] text-neutral-500">
        <span class="text-white/90">Independent advisor</span>
        <span class="ml-auto">
          <a href="mailto:julian@corbet.ch" class="text-neutral-400 hover:text-white transition-colors">
            julian@corbet.ch
          </a>
        </span>
      </div>
    </footer>

  </main>

  <style>
    @keyframes breathe {
      0%, 100% {
        transform: scale(1.000);
        opacity: 1;
      }
      50% {
        transform: scale(1.012);
        opacity: 0.94;
      }
    }
    .breathe {
      animation: breathe 9s ease-in-out infinite;
      will-change: transform, opacity;
    }
    .breathe-delay {
      animation: breathe 9s ease-in-out infinite;
      animation-delay: -3.5s;
      will-change: transform, opacity;
    }
    @media (prefers-reduced-motion: reduce) {
      .breathe, .breathe-delay { animation: none; }
    }
  </style>

</Base>

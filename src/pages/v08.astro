---
import Base from '../layouts/Base.astro';
import { services } from '../data/services';

const live = services
  .filter((s) => s.status === 'live' || s.status === 'forthcoming')
  .sort((a, b) => a.order - b.order);
---
<Base title="08 — Light — corbet.ch" bodyClass="font-sans bg-white text-neutral-900">
  <main class="min-h-screen flex flex-col" style="background:#ffffff;color:#0A0A0A;">

    <header class="max-w-6xl w-full mx-auto px-6 sm:px-10 pt-10 sm:pt-14">
      <p class="font-mono text-[10px] sm:text-[11px] uppercase tracking-[0.3em] text-neutral-500">
        Julian Corbet &nbsp;/&nbsp; corbet.ch
      </p>
    </header>

    <section class="flex-1 max-w-5xl w-full mx-auto px-6 sm:px-10 flex flex-col justify-center text-center py-20">
      <h1
        class="font-display font-bold leading-[0.95] tracking-[-0.022em] text-[clamp(2.5rem,9vw,7.5rem)]"
        style="color: #0A0A0A"
      >
        The world is changing.
      </h1>
      <p
        class="font-display italic font-medium mt-6 sm:mt-10 leading-[1.15] text-[clamp(1.4rem,4vw,2.75rem)]"
        style="color: var(--green-700)"
      >
        Looking for a running mate?
      </p>
    </section>

    <section class="max-w-5xl w-full mx-auto px-6 sm:px-10 pb-16 sm:pb-24">
      <ul class="border-t border-neutral-200">
        {live.map((s) => (
          <li class="border-b border-neutral-200">
            <a
              href={s.status === 'forthcoming' ? undefined : `https://${s.host}`}
              class="group flex flex-wrap items-baseline gap-x-6 gap-y-1 py-4 sm:py-5"
            >
              <span class="font-display italic text-xl sm:text-2xl text-neutral-900 group-hover:opacity-70 transition-opacity">
                {s.name}
              </span>
              <span class="font-sans text-sm text-neutral-500">
                {s.blurb}
              </span>
              <span class="ml-auto font-mono text-[10px] uppercase tracking-[0.3em] text-neutral-500">
                {s.status === 'forthcoming' ? 'forthcoming' : s.host}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <footer class="mt-auto border-t border-neutral-200">
      <div class="max-w-6xl mx-auto px-6 sm:px-10 py-5 sm:py-7 flex flex-wrap items-baseline gap-x-6 gap-y-2 font-mono text-[10px] sm:text-[11px] uppercase tracking-[0.3em] text-neutral-500">
        <span class="text-neutral-900">Independent advisor</span>
        <span class="ml-auto">
          <a href="mailto:julian@corbet.ch" class="text-neutral-500 hover:text-neutral-900 transition-colors">
            julian@corbet.ch
          </a>
        </span>
      </div>
    </footer>

  </main>
</Base>

---
import Base from '../layouts/Base.astro';
import { services } from '../data/services';

const live = services
  .filter((s) => s.status === 'live' || s.status === 'forthcoming')
  .sort((a, b) => a.order - b.order);
---
<Base title="10 — Terminal — corbet.ch" bodyClass="font-mono">
  <div class="scanlines fixed inset-0 pointer-events-none z-20"></div>

  <main class="min-h-screen flex flex-col relative z-10" style="background:#070A07;">

    <header class="max-w-5xl w-full mx-auto px-6 sm:px-10 pt-8 sm:pt-12 pb-2">
      <p class="font-mono text-[10px] sm:text-[11px] uppercase tracking-[0.25em]" style="color: var(--green-700)">
        ~/corbet.ch &nbsp;·&nbsp; tty1 &nbsp;·&nbsp; <span class="text-neutral-500">since 2026</span>
      </p>
    </header>

    <section class="max-w-5xl w-full mx-auto px-6 sm:px-10 pt-10 sm:pt-14 pb-10 font-mono">
      <p class="text-sm sm:text-base leading-[1.7]" style="color: var(--green-700)">
        <span class="opacity-60">$</span> whois julian
      </p>
      <pre class="mt-3 text-[clamp(0.95rem,1.6vw,1.05rem)] leading-[1.55] whitespace-pre-wrap" style="color: var(--ink)">
Julian Corbet      Independent advisor
                   Strategy / politics / financial services
                   Considered counsel, discreet operations.
</pre>

      <p class="mt-10 text-sm sm:text-base leading-[1.7]" style="color: var(--green-700)">
        <span class="opacity-60">$</span> cat slogan.txt
      </p>
      <pre class="mt-3 text-[clamp(1.4rem,4vw,2.5rem)] leading-[1.1] whitespace-pre-wrap font-sans font-semibold tracking-[-0.02em]" style="color: var(--ink)">
The world is changing.
<span style="color: var(--green-700);">  Looking for a running mate?</span>
</pre>

      <p class="mt-12 text-sm sm:text-base leading-[1.7]" style="color: var(--green-700)">
        <span class="opacity-60">$</span> ls -1 pages/
      </p>
      <ul class="mt-3 text-sm sm:text-base leading-[1.9]" style="color: var(--ink)">
        {live.map((s) => (
          <li class="grid grid-cols-[10rem_1fr] sm:grid-cols-[12rem_1fr] gap-x-6">
            <a
              href={s.status === 'forthcoming' ? undefined : `https://${s.host}`}
              class={s.status === 'forthcoming' ? 'opacity-60' : 'hover:underline'}
            >
              {s.host.replace('.corbet.ch', '')}
            </a>
            <span class="text-neutral-500 text-sm">
              {s.status === 'forthcoming' ? '[forthcoming]' : s.blurb}
            </span>
          </li>
        ))}
      </ul>

      <p class="mt-10 text-sm sm:text-base leading-[1.7]" style="color: var(--green-700)">
        <span class="opacity-60">$</span> <span class="cursor">_</span>
      </p>
    </section>

    <footer class="mt-auto border-t" style="border-color: rgba(21,128,61,0.2);">
      <div class="max-w-5xl mx-auto px-6 sm:px-10 py-5 sm:py-6 flex flex-wrap items-baseline gap-x-6 gap-y-2 text-[10px] sm:text-[11px] uppercase tracking-[0.25em] text-neutral-500">
        <span style="color: var(--green-700)">corbet.ch</span>
        <span class="ml-auto">
          <a href="mailto:julian@corbet.ch" class="hover:text-white transition-colors">julian@corbet.ch</a>
        </span>
      </div>
    </footer>

  </main>

  <style>
    @keyframes blink {
      0%, 60% { opacity: 1; }
      61%, 100% { opacity: 0; }
    }
    .cursor {
      display: inline-block;
      animation: blink 1.05s steps(1, end) infinite;
      color: var(--green-700);
    }
    .scanlines {
      background-image: repeating-linear-gradient(
        to bottom,
        rgba(0,0,0,0) 0,
        rgba(0,0,0,0) 2px,
        rgba(0,0,0,0.18) 3px,
        rgba(0,0,0,0) 4px
      );
      mix-blend-mode: multiply;
      opacity: 0.55;
    }
  </style>

</Base>

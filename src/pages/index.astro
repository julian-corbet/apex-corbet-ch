---
import Base from '../layouts/Base.astro';

const variants = [
  { n: '01', name: 'Cathedral',  hint: 'Cormorant monumental, no motion, no destinations. Pure statement.' },
  { n: '02', name: 'Bookplate',  hint: 'Cormorant + Geist Mono. Left-aligned. Hero + destination index. Quietest informational take.' },
  { n: '03', name: 'Whisper',    hint: 'Faint particle network behind. Slogan fades in. Destinations as a mono ticker.' },
  { n: '04', name: 'Streaming',  hint: 'Slogan types out once on load, LLM cadence. Counter + body fade in after.' },
  { n: '05', name: 'Paired',     hint: 'Study-19 register, single pair, no cycling. Lead + green echo, static.' },
  { n: '06', name: 'Numbered',   hint: 'Study-8 manifesto. 01/02/03 destinations as principles. Deepest green.' },
  { n: '07', name: 'Geist only', hint: 'Drop Cormorant entirely. Geist Sans heavy hero + Geist Mono labels.' },
  { n: '08', name: 'Light',      hint: 'Inverted: white background, charcoal ink, emerald-700. The brand’s only light-mode option.' },
  { n: '09', name: 'Breathing',  hint: 'Cormorant slogan with imperceptible scale + opacity breathing (9s loop).' },
  { n: '10', name: 'Terminal',   hint: 'Geist Mono only, faint scanlines, slogan as $ cat slogan.txt output. The risky one.' },
];
---
<Base title="apex — variant picker" bodyClass="font-sans">
  <main class="min-h-screen flex flex-col">

    <header class="max-w-5xl w-full mx-auto px-6 sm:px-10 pt-10 sm:pt-14">
      <p class="font-mono text-[10px] sm:text-[11px] uppercase tracking-[0.3em] text-neutral-500">
        corbet.ch &nbsp;/&nbsp; apex &nbsp;/&nbsp; variant picker
      </p>
      <h1 class="font-display font-bold mt-6 leading-[0.95] tracking-[-0.022em] text-[clamp(2rem,5vw,3.5rem)]" style="color: var(--ink)">
        Ten takes on the front door.
      </h1>
      <p class="font-sans text-sm sm:text-base leading-[1.7] text-neutral-300 mt-5 max-w-2xl">
        Each version is a complete take. Same slogan, same destinations, different register.
        Open a few side by side, kill the ones that don&rsquo;t feel right.
      </p>
    </header>

    <section class="max-w-5xl w-full mx-auto px-6 sm:px-10 pt-12 sm:pt-16 pb-16 sm:pb-24">
      <ul class="border-t border-white/[0.06]">
        {variants.map((v) => (
          <li class="border-b border-white/[0.06]">
            <a href={`/v${v.n}`} class="group block py-5 sm:py-6">
              <div class="flex flex-wrap items-baseline gap-x-6 gap-y-1">
                <span class="font-mono text-[11px] uppercase tracking-[0.3em]" style="color: var(--green-800)">
                  {v.n}
                </span>
                <span class="font-display italic text-2xl sm:text-3xl group-hover:text-white transition-colors" style="color: var(--ink)">
                  {v.name}
                </span>
              </div>
              <p class="font-sans text-sm text-neutral-400 mt-2 leading-relaxed max-w-3xl">
                {v.hint}
              </p>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <footer class="mt-auto border-t border-white/[0.06]">
      <div class="max-w-5xl mx-auto px-6 sm:px-10 py-5 sm:py-7 flex flex-wrap items-baseline gap-x-6 gap-y-2 font-mono text-[10px] sm:text-[11px] uppercase tracking-[0.3em] text-neutral-500">
        <span class="text-white/90">Tell me which two or three you like. Losers get deleted.</span>
      </div>
    </footer>

  </main>
</Base>

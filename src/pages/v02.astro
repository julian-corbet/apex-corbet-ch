---
import Base from '../layouts/Base.astro';
import { services } from '../data/services';

const live = services
  .filter((s) => s.status === 'live' || s.status === 'forthcoming')
  .sort((a, b) => a.order - b.order);
---
<Base title="02 — Bookplate — corbet.ch" bodyClass="font-sans">
  <main class="min-h-screen flex flex-col">

    <header class="max-w-6xl w-full mx-auto px-6 sm:px-10 pt-10 sm:pt-14">
      <p class="font-mono text-[10px] sm:text-[11px] uppercase tracking-[0.3em] text-neutral-500">
        Julian Corbet &nbsp;/&nbsp; corbet.ch
      </p>
    </header>

    <section class="max-w-5xl w-full mx-auto px-6 sm:px-10 pt-16 sm:pt-24 pb-12 sm:pb-16">
      <h1
        class="font-display font-bold leading-[0.95] tracking-[-0.022em] text-[clamp(2.25rem,8vw,6.5rem)]"
        style="color: var(--ink)"
      >
        The world is changing.
      </h1>
      <p
        class="font-display italic font-medium mt-5 sm:mt-8 leading-[1.15] text-[clamp(1.25rem,3.6vw,2.4rem)]"
        style="color: var(--green-800)"
      >
        Looking for a running mate?
      </p>

      <p class="font-sans text-sm sm:text-base leading-[1.7] text-neutral-300 mt-10 sm:mt-14 max-w-xl">
        Independent advisor at the intersection of strategy and politics.
        Considered counsel for leaders working where the maps are aging.
      </p>
    </section>

    <section class="max-w-5xl w-full mx-auto px-6 sm:px-10 pb-20 sm:pb-28">
      <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-neutral-500 mb-6">
        Pages
      </p>
      <ul class="border-t border-white/[0.06]">
        {live.map((s) => (
          <li class="border-b border-white/[0.06]">
            <a
              href={`https://${s.host}`}
              class="group flex flex-wrap items-baseline gap-x-6 gap-y-1 py-4 sm:py-5 transition-colors"
            >
              <span
                class="font-display italic text-xl sm:text-2xl group-hover:text-white transition-colors"
                style="color: var(--ink)"
              >
                {s.name}
              </span>
              <span class="font-sans text-sm text-neutral-400 group-hover:text-neutral-300 transition-colors">
                {s.blurb}
              </span>
              <span class="ml-auto font-mono text-[10px] uppercase tracking-[0.3em] text-neutral-500 group-hover:text-neutral-300 transition-colors">
                {s.status === 'forthcoming' ? 'forthcoming' : s.host}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <footer class="mt-auto border-t border-white/[0.06]">
      <div class="max-w-6xl mx-auto px-6 sm:px-10 py-5 sm:py-7 flex flex-wrap items-baseline gap-x-6 gap-y-2 font-mono text-[10px] sm:text-[11px] uppercase tracking-[0.3em] text-neutral-500">
        <span class="text-white/90">Independent advisor</span>
        <span class="ml-auto">
          <a href="mailto:julian@corbet.ch" class="text-neutral-400 hover:text-white transition-colors">
            julian@corbet.ch
          </a>
        </span>
      </div>
    </footer>

  </main>
</Base>
